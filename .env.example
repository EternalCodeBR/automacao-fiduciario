# Copie este arquivo para ".env" e preencha com os valores do seu ambiente.
# Nenhum valor real de produção deve ser commitado — ".env" está no .gitignore.

# --- Etapa 1: macro VBA (Excel COM) ---
PASTA_CALCULADORAS=C:\caminho\para\Calculadoras
MACRO_WORKBOOK=C:\caminho\para\Macro.xlsm
BASE_DADOS_MERCADO=C:\caminho\para\BaseDadosMercado.xlsm

# --- Etapa 2: upload no CMS ---
CMS_URL_LOGIN=https://seusite.exemplo.com/wp-login.php
CMS_USER=usuario@exemplo.com
CMS_PASS=troque-por-uma-senha-forte

# --- Etapa 3: notificação em chat (Power Automate / Teams, Slack webhook, etc.) ---
CHAT_WEBHOOK_URL=

# --- Lista de ativos monitorados (JSON) ---
# Opcional: sobrescreve a lista padrão definida em src/atualizar_precos.py
# ATIVOS_CONFIG=[{"nome":"Ativo A","padrao_arquivo":"Historico_PU_Ativo_A*.xls*","post_id":1001}]
